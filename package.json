{
  "name": "ethos-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "pnpm -r --filter='./packages/*' --filter='./extensions/*' --filter='./apps/*' run build",
    "dev": "tsx apps/ethos/src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "clean": "find . -name 'dist' -not -path '*/node_modules/*' -exec rm -rf {} + 2>/dev/null; true",
    "docs": "pnpm --filter docs run start",
    "docs:build": "pnpm --filter docs run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "pino": "^10.3.1",
    "playwright": "^1.59.1",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@discordjs/opus",
      "better-sqlite3",
      "esbuild",
      "playwright"
    ],
    "peerDependencyRules": {
      "ignoreMissing": [
        "zod"
      ]
    }
  }
}
